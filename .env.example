# Root compose/runtime env (copy to .env or .env.local, never commit real secrets)

# API
APP_URL=http://localhost:5174
API_PORT=3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/goodjob
REDIS_URL=redis://redis:6379
JWT_SECRET=dev-jwt-secret-change-me
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
OAUTH_TOKEN_ENCRYPTION_KEY=dev-oauth-token-encryption-key-32-char
GOOGLE_CLIENT_ID=local-google-client-id
GOOGLE_CLIENT_SECRET=local-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback
GEMINI_API_KEYS=local-gemini-key
AUTH_ALLOW_DEV_TOKEN_ISSUE=true
RESEND_TOKEN=

# Optional sender fallback (CI can use ADMIN_EMAIL secret)
ADMIN_EMAIL=

# Web
VITE_API_URL=http://localhost:3000/api
VITE_API_PROXY_TARGET=http://api:3000

# Live E2E
E2E_BASE_URL=http://localhost:5174
E2E_API_READY_URL=http://localhost:3000/api/ready
E2E_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/goodjob
