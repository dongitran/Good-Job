# ─────────────────────────────────────
# Good Job - Environment Variables
# ─────────────────────────────────────
# ⚠️  REQUIRED variables must be set
# ℹ️  OPTIONAL variables have defaults

# ⚠️  Application (REQUIRED)
NODE_ENV=development
APP_URL=http://localhost:5174

# ℹ️  API Port (Optional - defaults to 3000)
API_PORT=3000

# ⚠️  Database (REQUIRED)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/goodjob

# ⚠️  Redis (REQUIRED)
# Format: redis://localhost:6379  or  redis://:password@host:port
REDIS_URL=redis://localhost:6379

# ⚠️  JWT Authentication (REQUIRED)
JWT_SECRET=change-this-to-a-random-secret-in-production

# ℹ️  JWT Expiry (Optional - defaults shown)
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ⚠️  Google OAuth2 (REQUIRED for OAuth login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# ⚠️  OAuth Token Encryption (REQUIRED)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
OAUTH_TOKEN_ENCRYPTION_KEY=

# ⚠️  Gemini AI (REQUIRED for AI features)
# Multiple keys supported — separate with commas for round-robin rotation
# Example: GEMINI_API_KEYS=key1,key2,key3
GEMINI_API_KEYS=your-gemini-api-key

# ℹ️  Rate Limiting (Optional - defaults shown)
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# ⚠️  Points System (REQUIRED - business logic)
DEFAULT_MONTHLY_BUDGET=200
DEFAULT_MIN_POINTS=10
DEFAULT_MAX_POINTS=50
