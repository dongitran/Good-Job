NODE_ENV=test
API_PORT=3000
APP_URL=http://localhost:5173

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/goodjob_test
REDIS_URL=redis://localhost:6379

JWT_SECRET=test-secret
GOOGLE_CLIENT_ID=ci-google-client-id
GOOGLE_CLIENT_SECRET=ci-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback
OAUTH_TOKEN_ENCRYPTION_KEY=e2e-test-encryption-key-must-be-at-least-32-chars

